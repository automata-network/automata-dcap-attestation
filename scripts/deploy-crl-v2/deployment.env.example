# Required. The script refuses to continue if the RPC-reported chain ID differs.
RPC_URL=https://rpc.example.invalid
CHAIN_ID=1315

# Required. Use an absolute path to one encrypted Foundry keystore file.
KEYSTORE_PATH=/secure/path/to/dcap_prod

# Required by stages 03 and 06. Space- or comma-separated QPL/dashboard
# collateral workers. Replace both placeholders with the staging and production
# worker addresses. A single address is also accepted.
ATTESTER_ADDRESSES="REPLACE_WITH_STAGING_WORKER REPLACE_WITH_PRODUCTION_WORKER"

# Backward compatibility: a deployment with only one worker may still use the
# legacy singular setting. ATTESTER_ADDRESSES takes precedence when both exist.
# ATTESTER_ADDRESS=REPLACE_WITH_WORKER

# This rollout deploys only the currently used async FMSPC V2 implementation.
TCB_EVALUATION_NUMBERS="20 21"

# Optional for non-interactive deployments. The file should be mode 0600 and
# contain only the keystore password. If omitted, run-all.sh prompts once.
# KEYSTORE_PASSWORD_FILE=/secure/path/to/dcap_prod.password

# Optional transaction settings. CONFIRMATIONS applies to CRL migration transactions.
CONFIRMATIONS=1
# LEGACY=true
# SLOW=true
# INDEX_GAS_LIMIT=5000000
# SKIP_SIMULATION=true

# Router switching requires all three stored CRLs to be indexed by default.
REQUIRE_INDEXED_CRLS=true

# Destructive retirement is not part of run-all.sh. Set these only when
# evaluation 19 has expired and you intentionally run stages 07 and 08.
# RETIRED_TCB_EVALUATION_NUMBER=19
# MIN_ACTIVE_TCB_EVALUATION=20
# LEGACY_REVOKE_NOT_BEFORE=1789257600
# CONFIRM_LEGACY_PCS_REVOKE=true
